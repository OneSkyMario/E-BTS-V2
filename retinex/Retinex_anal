import cv2
import numpy as np


def single_scale_retinex(img: np.ndarray, sigma: float = 80) -> np.ndarray:
    """
    Apply Single Scale Retinex (SSR) to a color image.

    Args:
        img: Input BGR image as uint8.
        sigma: Gaussian blur sigma.

    Returns:
        Enhanced BGR image as uint8.
    """
    if img is None:
        raise ValueError("Input image is None.")
    if img.dtype != np.uint8:
        raise ValueError("Input image must be uint8.")

    # Convert to float and avoid log(0)
    img_float = img.astype(np.float32) + 1.0

    # Apply SSR channel-wise
    retinex = np.zeros_like(img_float)
    for c in range(3):
        channel = img_float[:, :, c]
        blur = cv2.GaussianBlur(channel, (0, 0), sigma)
        retinex[:, :, c] = np.log10(channel) - np.log10(blur + 1.0)

    # Normalize each channel to 0-255
    output = np.zeros_like(retinex)
    for c in range(3):
        ch = retinex[:, :, c]
        ch = (ch - np.min(ch)) / (np.max(ch) - np.min(ch) + 1e-8) * 255.0
        output[:, :, c] = ch

    return np.clip(output, 0, 255).astype(np.uint8)


if __name__ == "__main__":
    input_path = "input.jpg"     # change this to your image path
    output_path = "output.jpg"   # output image path

    img = cv2.imread(input_path)
    if img is None:
        raise FileNotFoundError(f"Could not read image: {input_path}")

    result = single_scale_retinex(img, sigma=80)

    cv2.imwrite(output_path, result)
    print(f"Saved enhanced image to: {output_path}")